{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "typeRoots": [
      "./src/common/types",
      "./node_modules/@types"
    ],
    "types": [
      "node"
    ],
    "lib": [
      "ES2022"
    ],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
