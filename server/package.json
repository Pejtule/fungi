{
  "name": "@fungi/server",
  "version": "1.0.0",
  "private": true,
  "description": "Backend application for the Fungi taxonomy management system",
  "author": "Petra Mollerová",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "imports": {
    "#config/*": "./src/infrastructure/config/*",
    "#modules/*": "./src/modules/*",
    "#middleware/*": "./src/common/middleware/*",
    "#utils/*": "./src/common/utils/*",
    "#infra/*": "./src/infrastructure/*"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/server.ts",
    "dev:debug": "cross-env NODE_ENV=development node --inspect-brk ./node_modules/.bin/tsx watch src/server.ts",
    "build": "cross-env NODE_ENV=production tsc && tsc-alias",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest --config vitest.config.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.3",
    "mime": "^4.1.0",
    "mongoose": "^9.0.2",
    "mongoose-lean-virtuals": "^2.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
